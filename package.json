{
  "name": "ai-shogi",
  "version": "0.1.0",
  "description": "AI同士の将棋対局を観戦・再生するLocalWebアプリ",
  "main": "src/server/server.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "start": "tsx src/server/server.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "lefthook install",
    "agent:black": "tsx src/agents/ollamaAgent.ts --side black --name 先手Gemma4",
    "agent:white": "tsx src/agents/ollamaAgent.ts --side white --name 後手Gemma4",
    "agents": "concurrently -k -n black,white -c magenta,cyan \"pnpm run agent:black\" \"pnpm run agent:white\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26.4.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsshogi": "^2.3.4",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "lefthook": "^2.1.10",
    "vitest": "^4.1.10"
  }
}
